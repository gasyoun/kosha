# kosha environment template — copy to .env
DATABASE_PATH=./unified_dict.db
LOG_LEVEL=INFO
# NB: cookie-scoped personal history (/api/v1/history, /api/v1/auth/*) needs
# credentialed CORS, which Starlette refuses to combine with a wildcard
# origin. In production, set this to an explicit list, e.g.
# CORS_ORIGINS=["https://samskrtam.ru", "https://gasyoun.github.io"]
CORS_ORIGINS=["*"]
# Cologne scans are served by csl-websanlexicon serveimg/servepdf:
COLOGNE_SCAN_BASE=https://www.sanskrit-lexicon.uni-koeln.de

# Search-history / analytics store (separate SQLite file from the read-only
# dictionary DB, so the monthly dict rebuild never touches it). Defaults to
# data/db/kosha_history.db if unset.
HISTORY_DB_PATH=./data/db/kosha_history.db
# Salt for hashing visitor IPs before storage — never store raw IPs. Set a
# real random value in production; the default is dev-only.
HISTORY_IP_SALT=kosha-dev-salt
